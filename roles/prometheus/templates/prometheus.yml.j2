global:
  scrape_interval: {{ prometheus_scrape_interval }}

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['127.0.0.1:9090']

  - job_name: 'node_exporters'
    static_configs:
      - targets:
{% for host in groups['linux_nodes'] %}
          - '{{ host }}:9100'
{% endfor %}
